LLM_PROVIDER=volcengine_ark
LLM_API_KEY=
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=ep-xxxxxxxxxxxxxxxx
LLM_TIMEOUT_SECONDS=240
LLM_MAX_RETRIES=2
LLM_MAX_TOKENS=2500

NOTION_TOKEN=
NOTION_DATABASE_ID=

# Customer intake V1 web app
GITHUB_TOKEN=
GITHUB_REPO=vivi9116/first-diagnosis-report-tool
GITHUB_WORKFLOW_ID=generate-report.yml
GITHUB_REF=main
AUTO_TRIGGER_GITHUB=true

# JSON. Temporary invite only exposes first_diagnosis.
# Formal account exposes weekly/monthly according to allowedReports.
INTAKE_ACCESS_CONFIG={"temporaryInvites":{"DEMO-FIRST":{"customerId":"C-DEMO","customerName":"演示首诊客户","reportType":"first_diagnosis"}},"formalAccounts":{"DEMO-VIP":{"accountId":"A-DEMO","customerId":"VIP-DEMO","customerName":"演示正式客户","plan":"standard","allowedReports":["weekly","monthly"]}}}
